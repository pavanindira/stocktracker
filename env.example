# ─────────────────────────────────────────────────────────────────────────────
# StockTracker — Environment Variables
# Copy this file to .env and fill in your values before starting.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose builds DATABASE_URL automatically from the POSTGRES_* vars.
# For a bare-metal install, set DATABASE_URL directly instead:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/stocktracker

POSTGRES_DB=stocktracker
POSTGRES_USER=stocktracker
POSTGRES_PASSWORD=change-this-strong-password

# ── Admin seed (first startup only) ──────────────────────────────────────────
# Change via /admin panel immediately after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=System Administrator

# ── Docker / Uvicorn ──────────────────────────────────────────────────────────
# Number of Uvicorn worker processes. Recommended: 2× CPU cores.
WORKERS=2
HTTP_PORT=80
# HTTPS_PORT=443

# ── Push Notifications (Firebase FCM) ────────────────────────────────────────
# Leave blank to disable push notifications entirely (app still works normally).
#
# How to get your server key:
#   1. Go to https://console.firebase.google.com
#   2. Select your project → Project Settings → Cloud Messaging
#   3. Copy the "Server key" from the Cloud Messaging API (Legacy) section
#
# Note: The mobile app also needs google-services.json (Android) and
# GoogleService-Info.plist (iOS) placed in the respective platform folders.
FCM_SERVER_KEY=

# ── Email Digest (SMTP) ───────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email digests entirely.
#
# Daily digest emails are sent to each shop's registered email address.
# They include: yesterday's sales total, low-stock products, expiry alerts.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-app-password   ← generate at myaccount.google.com/apppasswords
#   SMTP_FROM=StockTracker <youraddress@gmail.com>
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.your-sendgrid-api-key
#   SMTP_FROM=noreply@yourdomain.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Hour (UTC, 0–23) at which the daily digest is sent. Default: 8 = 8:00am UTC.
DIGEST_HOUR=8
