# Copy this file to .env and fill in your values
DATABASE_URL=postgresql://postgres:password@localhost:5432/stocktracker
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Default admin account (created automatically on first startup)
# Change these or override via environment variables
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=System Administrator
